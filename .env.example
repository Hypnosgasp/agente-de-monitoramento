# ==========================================================
# Copie este arquivo para ".env" e preencha com valores reais.
# NUNCA suba o arquivo ".env" (com senhas reais) para nenhum
# repositório Git público ou compartilhado.
# ==========================================================

# --- Postgres (compartilhado entre n8n, Evolution API e o app) ---
POSTGRES_USER=admin_monitoring
POSTGRES_PASSWORD=troque-esta-senha-por-uma-forte

# --- n8n ---
# Gere uma chave aleatória forte, ex: openssl rand -hex 32
N8N_ENCRYPTION_KEY=troque-esta-chave
# IP ou hostname do servidor local onde o n8n vai rodar
N8N_HOST=192.168.0.10
# URL completa usada para montar os links de webhook (deve bater com N8N_HOST)
N8N_WEBHOOK_URL=http://192.168.0.10:5678/
# Login básico para acessar a interface do n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=troque-esta-senha-tambem

# --- Evolution API ---
# URL pela qual a própria Evolution API se identifica (mesma rede local)
EVOLUTION_SERVER_URL=http://192.168.0.10:8080
# Chave de API que você vai usar no header "apikey" ao chamar a Evolution API
# a partir do n8n. Gere algo aleatório e forte.
EVOLUTION_API_KEY=troque-esta-chave-tambem
